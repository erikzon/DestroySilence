@page "/"
@using FFmpegBlazor
@using System.IO.IsolatedStorage

<PageTitle>Destroy Silence</PageTitle>

<div class="container mt-4">
    <h1>@Loc["Title"]</h1>
    <p>@Loc["Subtitle"]</p>

    <div class="row mb-4 p-3 border rounded bg-light">
        <div class="col-md-6">
            <label class="form-label fw-bold">@Loc["NoiseThreshold"] @noiseThreshold dB</label>
            <input type="range" class="form-range" min="-60" max="0" step="1" value="@noiseThreshold" @oninput="UpdateThreshold" />
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">@Loc["MinSilenceDuration"]</label>
            <input type="number" step="0.1" class="form-control" @bind="silenceDuration" />
        </div>
    </div>

    <InputFile id="fileInputElem" @ref="fileInputRef" OnChange="OnFileSelected" class="form-control mb-3" />

    <div class="mb-4" style="@(hasFile ? "display:block;" : "display:none;")">
        <label class="fw-bold">@Loc["AudioPreview"]</label><br />
        <canvas id="waveformCanvas" width="800" height="150" class="border rounded bg-dark w-100"></canvas>
    </div>

    <button class="btn btn-primary" @onclick="ProcessVideo" disabled="@(!hasFile || isProcessing)">
        @(isProcessing ? Loc["Processing"] : Loc["RemoveSilence"])
    </button>

    @if (isProcessing)
    {
        <div class="mt-4">
            <p class="text-info fw-bold">@progressPhase</p>
            <div class="progress" style="height: 25px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
                     style="width: @(Math.Round(processingPercentage))%;" aria-valuenow="@processingPercentage"
                     aria-valuemin="0" aria-valuemax="100">
                    @(Math.Round(processingPercentage))%
                </div>
            </div>
        </div>
    }

    @if (isDone)
    {
        <p class="mt-3 text-success fw-bold">@Loc["ProcessCompleted"]</p>
    }
    
</div>

