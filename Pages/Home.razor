@page "/"
@using FFmpegBlazor
@using System.IO.IsolatedStorage

<PageTitle>Destroy Silence</PageTitle>

<canvas id="three-bg-canvas" class="background-canvas"></canvas>

<div class="glass-container mt-4">
    <h1 class="accent-text">@Loc["Title"]</h1>
    <p class="sub-text">@Loc["Subtitle"]</p>

    <div class="file-upload-wrapper mb-4">
        <div class="drop-zone">
            <InputFile id="fileInputElem" @ref="fileInputRef" OnChange="OnFileSelected" class="custom-file-input drop-zone-input" title="" />
            <div class="drop-zone-text">
                @if (hasFile && selectedFile != null)
                {
                    <span class="accent-text">@selectedFile.Name</span>
                }
                else
                {
                    <span>@Loc["DropFileHere"]</span>
                }
            </div>
        </div>
    </div>

    <div class="glass-panel mb-4" style="@(hasFile ? "display:block;" : "display:none;")">
        <div class="row g-4">
            <div class="col-md-6">
                <label class="custom-label">@Loc["NoiseThreshold"] <span class="accent-text">@noiseThreshold dB</span></label>
                <input type="range" class="custom-range" min="-60" max="0" step="1" value="@noiseThreshold" @oninput="UpdateThreshold" />
            </div>
            <div class="col-md-6">
                <label class="custom-label">@Loc["MinSilenceDuration"]</label>
                <input type="number" step="0.1" class="custom-input" @bind="silenceDuration" />
            </div>
        </div>
    </div>

    <div class="glass-panel mb-4" style="@(hasFile ? "display:block;" : "display:none;")">
        <label class="custom-label">@Loc["AudioPreview"]</label>
        <canvas id="waveformCanvas" width="800" height="150" class="waveform-canvas w-100"></canvas>
    </div>

    <button class="action-btn" @onclick="ProcessVideo" disabled="@(!hasFile || isProcessing)">
        <span class="btn-text">@(isProcessing ? Loc["Processing"] : Loc["RemoveSilence"])</span>
    </button>

    @if (isProcessing)
    {
        <div class="mt-4 glass-panel progress-panel">
            <p class="accent-text">@progressPhase</p>
            <div class="custom-progress">
                <div class="custom-progress-bar" style="width: @(Math.Round(processingPercentage))%;"></div>
            </div>
            <span class="progress-text">@(Math.Round(processingPercentage))%</span>
        </div>
    }

    @if (isDone)
    {
         <p class="mt-3 success-text">@Loc["ProcessCompleted"]</p>
    }
</div>
